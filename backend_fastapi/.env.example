# ============================================================================
# CONFIGURACIÓN MONGODB
# ============================================================================
# URL de conexión a MongoDB
# Docker local: mongodb://admin:Panconpalta1@localhost:27017/
# Dentro de Docker (desde otro contenedor): mongodb://admin:Panconpalta1@mongodb:27017/
MONGODB_URL=mongodb://admin:Panconpalta1@localhost:27017/
MONGODB_DB=Arandanos

# ============================================================================
# CONFIGURACIÓN MAILERSEND (ALERTAS POR EMAIL)
# ============================================================================
MAILERSEND_API_TOKEN=tu_api_token_aqui
MAILERSEND_FROM_EMAIL=noreply@tudominio.com
MAILERSEND_FROM_NAME=Monitoreo Embalse Arandanos
MAILERSEND_TO_EMAILS=email1@example.com,email2@example.com

# ============================================================================
# CONFIGURACIÓN GENERAL
# ============================================================================
# Puerto en el que corre la API
API_PORT=8000

# Host para la API
API_HOST=0.0.0.0
