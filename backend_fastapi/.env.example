# ============================================================================
# CONFIGURACIÓN MONGODB
# ============================================================================
# URL de conexión a MongoDB
# Docker local: mongodb://admin:Panconpalta1@localhost:27017/
# Dentro de Docker (desde otro contenedor): mongodb://admin:Panconpalta1@mongodb:27017/
# Railway/Atlas: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_URL=mongodb://admin:Panconpalta1@localhost:27017/?authSource=admin
MONGODB_DB=Arandanos
SIMULATED_DATA_ENABLED=false

# ============================================================================
# CONFIGURACIÓN MAILERSEND (ALERTAS POR EMAIL)
# ============================================================================
MAILERSEND_API_TOKEN=tu_api_token_aqui
MAILERSEND_FROM_EMAIL=noreply@tudominio.com
MAILERSEND_FROM_NAME=Monitoreo Embalse Arandanos
MAILERSEND_TO_EMAILS=email1@example.com,email2@example.com
MAILERSEND_TEMPLATE_ID=351ndgw8m7rgzqx8
MAILERSEND_MAX_RECIPIENTS_PER_REQUEST=1

# ============================================================================
# CONFIGURACIÓN GENERAL
# ============================================================================
# Puerto en el que corre la API
API_PORT=8000

# Host para la API
API_HOST=0.0.0.0

# ============================================================================
# JWT (login dashboard: administrador / empleado)
# ============================================================================
# Secreto HS256 (obligatorio en producción)
JWT_SECRET=cambiar_por_secreto_largo_y_aleatorio
# Access token administrador (minutos)
JWT_ACCESS_MINUTES_ADMIN=30
# Access token empleado (horas)
JWT_ACCESS_HOURS_EMPLOYEE=8
# Refresh token ambos roles (días)
JWT_REFRESH_DAYS=7
# Contraseña demo para login (misma que usa la vista Login hasta integrar otra fuente)
AUTH_DEMO_PASSWORD=123456789
